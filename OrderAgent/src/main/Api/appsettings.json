{
  "Application": {
    "Name": "gRPC.Server.Api",
    "Version": "1.0.0"
  },
  "Serilog": {
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/metrics' or RequestPath like '/health' or RequestPath like '/favicon%'"
        }
      }
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  },
  "Mcp": {
    "ApiKeyAuthentication": {
      "HeaderName": "x-api-key",
      "ApiKeys": [
        {
          "ClientId": "mcp-readonly-client",
          "ClientName": "MCP Readonly Client",
          "KeyHash": "ad7c8cf0ff375d1b84277536e4cb794ec92f5667d82b481b4a68b325e5d96965",
          "IsEnabled": true,
          "Scopes": [
            "profiles.read"
          ]
        },
        {
          "ClientId": "mcp-admin-client",
          "ClientName": "MCP Admin Client",
          "KeyHash": "7f9ad30d6b7bcdaa301e3af2377edde330b96e3dcf56f8ab8b0f0ff0f1f10df7",
          "IsEnabled": true,
          "Scopes": [
            "profiles.create",
            "profiles.activate",
            "profiles.inactivate",
            "profiles.read"
          ]
        }
      ]
    }
  }
}
